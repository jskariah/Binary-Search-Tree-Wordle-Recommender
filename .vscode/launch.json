{
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build bstset_main",
      "name": "Debug BST Main",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/bstset_main",
    },
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build bstset_tests",
      "name": "Debug BST Core",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/bstset_tests",
      "args": [
        "--gtest_color=yes",
        "--gtest_filter=BSTSetCore*",
      ],
    },
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build bstset_tests",
      "name": "Debug BST Aug",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/bstset_tests",
      "args": [
        "--gtest_color=yes",
        "--gtest_filter=BSTSetAugmented*",
      ],
    },
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build bstset_tests",
      "name": "Debug BST Erase",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/bstset_tests",
      "args": [
        "--gtest_color=yes",
        "--gtest_filter=BSTSetErase*",
      ],
    },
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build wordle_main",
      "name": "Debug Wordle Main",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/wordle_main",
    },
    {
      "type": "lldb",
      "request": "launch",
      "preLaunchTask": "build wordle_tests",
      "name": "Debug Wordle Tests",
      "cwd": "${workspaceFolder}",
      "env": {
        "ASAN_OPTIONS": "abort_on_error=1:detect_leaks=0",
      },
      "program": "${workspaceFolder}/wordle_tests",
      "args": [
        "--gtest_color=yes",
        "--gtest_filter=Wordle*",
      ],
    },
  ],
}
